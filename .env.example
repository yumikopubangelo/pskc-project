# ============================================================
# PSKC — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git
# ============================================================

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=debug
SECRET_KEY=ganti_dengan_random_string_yang_panjang
TRUSTED_PROXIES=
AUDIT_LOG_DIRECTORY=/app/logs
DATABASE_URL=
DATABASE_PATH=

# HTTP Security Middleware
FIPS_SELF_TEST_ENABLED=true
HTTP_SECURITY_ENABLED=true
HTTP_SECURITY_BLOCK_SENSITIVE_FROM_EXTERNAL=false
HTTP_SECURITY_MAX_REQUEST_BODY_BYTES=10485760
HTTP_RATE_LIMIT_ENABLED=true
HTTP_RATE_LIMIT_MAX_REQUESTS=300
HTTP_RATE_LIMIT_WINDOW_SECONDS=60
HTTP_RATE_LIMIT_BURST_MAX=60
HTTP_RATE_LIMIT_BURST_WINDOW_SECONDS=5
HTTP_RATE_LIMIT_WHITELIST_PRIVATE_IPS=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=pskc_redis_secret
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=0.5
REDIS_SOCKET_TIMEOUT_SECONDS=0.5
REDIS_FAILURE_BACKOFF_SECONDS=30

# Cache (PSKC Core Settings)
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=10000
CACHE_ENCRYPTION_KEY=ganti_dengan_key_aes256_32_karakter

# ML Model
ML_MODEL_NAME=pskc_model
ML_MODEL_REGISTRY_DIR=data/models
ML_MODEL_STAGE=development
ML_MODEL_SIGNING_KEY=
ML_MODEL_PATH=data/models/pskc_model.pskc.json
ML_PREDICTION_THRESHOLD=0.75
ML_UPDATE_INTERVAL_SECONDS=30
ML_TOP_N_PREDICTIONS=10

# Simulation Mode
SIMULATION_MODE=true
SIMULATION_SCENARIO=all

# Monitoring (opsional)
GRAFANA_PASSWORD=admin

# Security API Keys (format: "key1:service1,key2:service2")
# Required for /security/* endpoints in production
PSKC_API_KEYS=
